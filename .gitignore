Thumbs.db
Icon?

# macOS Finder / cloud-sync duplicate artifacts (e.g. "core 2.py", "index 3.md").
# These are copy-collision cruft, never real source. Guard added by the WS0
# consistency baseline after 71 such files accumulated in the working tree.
* [0-9].py
* [0-9].json
* [0-9].md
* [0-9].txt
* [0-9].yml
* [0-9].yaml
* [0-9].csv

# Obsidian
.obsidian/

# Wiki — dynamic content not committed; seed files force-tracked
wiki/hot.md
wiki/log.md
wiki/upgrade-reports/

# Ruflo / RuVector databases (local runtime state)
# IMPORTANT: Never include these in a ZIP upload to Claude Code.
# ruvector.db compresses 580:1 and triggers the security scanner.
# Always use GitHub "Download ZIP" — it excludes gitignored files automatically.
*.rvf
*.rvf.lock
ruvector.db
agentdb.rvf
agentdb.rvf.lock

# Zeref trace logs (local runtime)
zeref-trace.jsonl

# Zeref structured memory state (local runtime)
memory/state/*.sqlite
memory/state/*.sqlite-*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv/
venv/
build/
dist/
*.egg-info/
.pytest_cache/

# Node
node_modules/
npm-debug.log

# Editor
.vscode/
*.swp
*.swo

# Claude Code local settings and project configs (user-specific, not part of plugin)
.claude/settings.local.json
.claude/launch.json
.claude/

# Zeref local runtime memory artifacts
memory/hot.md
memory/index.md
memory/MEMORY.md
memory/DECISIONS.md
memory/OPEN_QUESTIONS.md
memory/RISKS.md
memory/CONFLICTS.md
memory/audit/
