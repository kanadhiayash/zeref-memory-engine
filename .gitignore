memory/views/
memory/snapshots/
memory/sync/

# Release-check evidence blobs are generated locally by zeref/release/checks.py.
# Raw evidence dumps are operator records kept outside this repository
# and must not re-enter the public tree.
docs/audits/release-evidence/

# Local lineage sandbox imports. Foreign repository clones and inventories are
# generated evidence only and must not enter Zeref core.
.zeref-sandbox/
