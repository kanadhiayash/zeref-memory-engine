# Obsidian
.obsidian/

# Wiki — dynamic content not committed; seed files force-tracked
wiki/hot.md
wiki/log.md
wiki/upgrade-reports/

# Ruflo / RuVector databases (local runtime state)
# IMPORTANT: Never include these in a ZIP upload to Claude Code.
# ruvector.db compresses 580:1 and triggers the security scanner.
# Always use GitHub "Download ZIP" — it excludes gitignored files automatically.
*.rvf
*.rvf.lock
ruvector.db
agentdb.rvf
agentdb.rvf.lock

# Zeref trace logs (local runtime)
zeref-trace.jsonl

# Zeref structured memory state (local runtime)
memory/state/*.sqlite
memory/state/*.sqlite-*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv/
venv/

# Node
node_modules/
npm-debug.log

# Editor
.vscode/
*.swp
*.swo

# Claude Code local settings and project configs (user-specific, not part of plugin)
.claude/settings.local.json
.claude/launch.json
.claude/

